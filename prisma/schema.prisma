// Prisma schema — crm-salon-infantil
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ───────────────────────────────────────────────────────────────────
// Maps Bonete event states. SENADO = "Señado" (deposit paid).
enum EventState {
  PRESUPUESTADO // quoted, not yet confirmed
  RESERVADO     // confirmed reservation
  SENADO        // deposit ("seña") received
  PAGADO        // fully paid
  EN_CURSO      // event running right now (consumption capture enabled)
  CERRADO       // closed / complete
  SUSPENDIDO    // cancelled / suspended
}

// ─── Client ───────────────────────────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String
  dni       String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

// ─── Event Type catalog ───────────────────────────────────────────────────────
model EventType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Event ───────────────────────────────────────────────────────────────────
model Event {
  id          String             @id @default(cuid())
  name        String
  eventType   String
  clientName  String
  clientId    String?
  startAt     DateTime
  endAt       DateTime
  state       EventState         @default(PRESUPUESTADO)
  details     String?
  notes       String?
  totalPrice  Int                @default(0) // stored in cents (centavos)
  // Consumption (consumos) session lifecycle. "Iniciar evento" stamps
  // consumosStartedAt and moves state to EN_CURSO; "Cerrar consumos" stamps
  // consumosClosedAt and freezes the lines. Payment state lives on each
  // EventConsumo line (paid/paidAt) because the bill can be settled in parts:
  // one payment for the client's lines plus one per self-paying guest.
  consumosStartedAt DateTime?
  consumosClosedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  client      Client?            @relation(fields: [clientId], references: [id])
  services    EventService[]
  providers   EventProvider[]
  bonificados EventBonificado[]
  staff       EventStaff[]
  consumos    EventConsumo[]

  @@index([startAt])
  @@index([state])
  @@index([clientId])
}

// ─── Proveedor (external vendor linked to a service) ─────────────────────────
model Proveedor {
  id          String    @id @default(cuid())
  name        String
  description String?
  phone       String?
  email       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  compras     Compra[]
}

// ─── Insumo (supply item — stock/inventory catalog) ──────────────────────────
// A consumable the venue buys from a Proveedor (gaseosas, gas, platos, bolsas…).
// Phase 1: master data + a plain on-hand stock count. Purchases (which raise
// stock) and consumption arrive in later phases. Quantities are whole units;
// `unit` records what one unit means (unidad/litro/kg/caja).
model Insumo {
  id          String       @id @default(cuid())
  name        String
  unit        String       @default("unidad")
  stockQty    Int          @default(0) // current on-hand count, whole units
  minStock    Int          @default(0) // low-stock alert threshold
  eventPrice  Int          @default(0) // cents — what the client pays per unit consumed at an event
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  compraLines CompraLine[]
  movements   StockMovement[]
  consumos    EventConsumo[]

  @@index([name])
}

// ─── StockMovement (append-only stock ledger) ────────────────────────────────
// Every change to an insumo's on-hand count appends one row here. `stockQty` on
// Insumo stays the fast running count (source of truth for reads); this ledger
// is the audit trail of HOW it got there. `delta` is signed: + adds stock
// (compra), − removes it (consumo/merma); ajuste can be either. `compraId` links
// the rows a purchase generated (cascade-removed if the compra is deleted).
model StockMovement {
  id        String   @id @default(cuid())
  insumoId  String
  kind      String // "compra" | "consumo" | "ajuste" | "merma"
  delta     Int // signed units: + in, − out
  reason    String?
  compraId  String?
  createdAt DateTime @default(now())
  insumo    Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  compra    Compra?  @relation(fields: [compraId], references: [id], onDelete: Cascade)

  @@index([insumoId])
  @@index([kind])
}

// ─── Compra (purchase of insumos from a Proveedor) ───────────────────────────
// A purchase invoice: one header (proveedor, date, total) holding many lines.
// Recording a Compra raises each line's insumo stock immediately. The Compra is
// a payable — settled later from Pago a proveedores, which marks it paid and
// posts an EGRESO movement (mirrors how prestador/staff payments settle).
// `total` is derived (sum of line qty × unitCost) and persisted in cents.
model Compra {
  id          String       @id @default(cuid())
  proveedorId String
  date        DateTime     @default(now())
  total       Int          @default(0) // cents — sum of line qty × unitCost
  paid        Boolean      @default(false)
  paidAt      DateTime?
  // EGRESO movement that settled this purchase (see EventProvider.paidMovementId).
  paidMovementId String?   @unique
  paidMovement   Movement? @relation("CompraPayment", fields: [paidMovementId], references: [id])
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  proveedor   Proveedor       @relation(fields: [proveedorId], references: [id])
  lines       CompraLine[]
  stockMoves  StockMovement[]

  @@index([proveedorId])
  @@index([paid])
  @@index([date])
}

// ─── Compra ↔ Insumo line ────────────────────────────────────────────────────
model CompraLine {
  id       String @id @default(cuid())
  compraId String
  insumoId String
  qty      Int // whole units purchased
  unitCost Int // cents per unit at purchase time (snapshot)
  compra   Compra @relation(fields: [compraId], references: [id], onDelete: Cascade)
  insumo   Insumo @relation(fields: [insumoId], references: [id])

  @@index([compraId])
  @@index([insumoId])
}

// ─── EventConsumo (per-table consumption during a running event) ─────────────
// One line per item a table requests while the event is EN_CURSO. The space has
// a fixed number of tables (TABLE_COUNT in lib/consumos/schema.ts); tableNumber
// records which one asked. `unitPrice` snapshots Insumo.eventPrice at capture
// time so later catalog edits never move an already-recorded bill. Recording a
// line deducts stock through the StockMovement ledger (kind "consumo-evento");
// removing it appends the reversing ledger row. Stock entries are NOT linked by
// FK on purpose: deleting an event must not silently restore consumed stock.
model EventConsumo {
  id          String   @id @default(cuid())
  eventId     String
  insumoId    String
  tableNumber Int // 1..TABLE_COUNT (Mesa 1–5)
  qty         Int // whole units consumed
  unitPrice   Int // cents per unit — snapshot of Insumo.eventPrice at capture
  // Who owes this line. CLIENTE lines form the organizer's bill (settled in
  // one payment at close); INVITADO lines are owed by a self-paying guest,
  // identified by payerLabel, and can be charged at any time per guest.
  payerType   String   @default("CLIENTE") // "CLIENTE" | "INVITADO"
  payerLabel  String? // who the guest is (e.g. "Tío Juan") — required for INVITADO
  paid        Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  insumo      Insumo   @relation(fields: [insumoId], references: [id])

  @@index([eventId])
  @@index([insumoId])
  @@index([payerType])
}

// ─── Service catalog ─────────────────────────────────────────────────────────
model Service {
  id           String         @id @default(cuid())
  name         String
  description  String?
  cost         Int            @default(0)  // what the venue pays, in cents
  price        Int            @default(0)  // what the client pays, in cents
  prestadorId  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  prestador    Provider?      @relation(fields: [prestadorId], references: [id])
  events       EventService[]
  bonificados  EventBonificado[] @relation("BonificadoService")

  @@index([prestadorId])
}

// ─── Event ↔ Service join ─────────────────────────────────────────────────────
model EventService {
  id        String    @id @default(cuid())
  eventId   String
  serviceId String
  qty       Int       @default(1)
  paid      Boolean   @default(false)
  paidAt    DateTime?
  // EGRESO movement that settled this prestador line (see EventProvider.paidMovementId).
  paidMovementId String? @unique
  paidMovement   Movement? @relation("ServicePayment", fields: [paidMovementId], references: [id])
  createdAt DateTime  @default(now())
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id])

  @@unique([eventId, serviceId])
  @@index([serviceId])
}

// ─── Bonificados (complimentary / waived services) ───────────────────────────
model EventBonificado {
  id        String  @id @default(cuid())
  eventId   String
  serviceId String
  qty       Int     @default(1)
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  service   Service @relation("BonificadoService", fields: [serviceId], references: [id])

  @@unique([eventId, serviceId])
  @@index([serviceId])
}

// ─── Prestador (provider / staff) ────────────────────────────────────────────
model Provider {
  id        String          @id @default(cuid())
  name      String
  role      String?                         // e.g. "DJ", "Fotógrafo", "Animador"
  cost      Int             @default(0)     // what the venue pays them per event, in cents
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  events    EventProvider[]
  services  Service[]
}

// ─── Event ↔ Provider join ────────────────────────────────────────────────────
model EventProvider {
  id         String    @id @default(cuid())
  eventId    String
  providerId String
  // Per-event cost in cents — always explicit (never null). On assign it is
  // snapshotted from the provider's catalog cost; the user can override it per
  // event (e.g. catering whose price varies). Feeds financials and pago reports.
  cost       Int       @default(0)
  paid       Boolean   @default(false)
  paidAt     DateTime?
  // The EGRESO movement that settled this line (set at payment, cleared on
  // reversal). Lets "Anular pago" reverse the EXACT amount paid, not a recompute.
  paidMovementId String? @unique
  paidMovement   Movement? @relation("ProviderPayment", fields: [paidMovementId], references: [id])
  createdAt  DateTime  @default(now())
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  provider   Provider  @relation(fields: [providerId], references: [id])

  @@unique([eventId, providerId])
  @@index([providerId])
}

// ─── Personal (internal hourly-paid staff) ──────────────────────────────────
// Distinct from Provider (external prestador, fixed cost per event). Staff are
// internal employees paid by the hour: an event may run 3h but an employee
// works 4–5h (setup, teardown). Their hours are a venue COST, never billed to
// the client (already covered by the event price).
model Staff {
  id         String       @id @default(cuid())
  name       String
  role       String?                       // e.g. "Mozo", "Coordinador", "Limpieza"
  hourlyRate Int          @default(0)       // what the venue pays per hour, in cents
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  events     EventStaff[]
}

// ─── Event ↔ Staff join ──────────────────────────────────────────────────────
// estMinutes = estimated hours at assignment; actualMinutes = real hours logged
// after the event (null = "falta registro de empleados"). Both are multiples of
// 30 (half-hour granularity). Cost uses actualMinutes ?? estMinutes.
model EventStaff {
  id            String    @id @default(cuid())
  eventId       String
  staffId       String
  estMinutes    Int?                        // estimated minutes at assignment
  actualMinutes Int?                        // real minutes logged after the event; null = unregistered
  paid          Boolean   @default(false)
  paidAt        DateTime?
  // EGRESO movement that settled this staff assignment (see EventProvider.paidMovementId).
  paidMovementId String? @unique
  paidMovement   Movement? @relation("StaffPayment", fields: [paidMovementId], references: [id])
  createdAt     DateTime  @default(now())
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staff         Staff     @relation(fields: [staffId], references: [id])

  @@unique([eventId, staffId])
  @@index([staffId])
}

// ─── Finanzas ─────────────────────────────────────────────────────────────────

enum MovementType {
  INGRESO
  EGRESO
  TRANSFERENCIA
  ARQUEO
  INVERSION
  RETIRO
}

model Account {
  id          String     @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  movements   Movement[] @relation("AccountMovements")
  inbound     Movement[] @relation("AccountInbound")
}

model Movement {
  id            String       @id @default(cuid())
  accountId     String
  toAccountId   String?      // only for TRANSFERENCIA
  type          MovementType
  // Discriminator for special INGRESO flavors. null = regular movement (cobros,
  // manual entries); "consumo" = payment of an event's consumption bill. Kept
  // separate so the event's Cobrado/Saldo (which compare against totalPrice)
  // never count the consumption bill, while account balances still do.
  kind          String?
  amount        Int          // stored in cents (centavos)
  description   String?
  date          DateTime     @default(now())
  eventId       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  account       Account      @relation("AccountMovements", fields: [accountId], references: [id])
  toAccount     Account?     @relation("AccountInbound", fields: [toAccountId], references: [id])
  // Back-relations for the payment line this EGRESO settled (at most one of each;
  // set when a line is paid, cleared when its payment is reversed via "Anular pago").
  providerPayment EventProvider? @relation("ProviderPayment")
  servicePayment  EventService?  @relation("ServicePayment")
  staffPayment    EventStaff?    @relation("StaffPayment")
  compraPayment   Compra?        @relation("CompraPayment")

  @@index([date])
  @@index([eventId])
  @@index([accountId])
  @@index([toAccountId])
}

// ─── Audit: removed consumption lines ─────────────────────────────────────────
// Append-only snapshot taken when a consumption line is voided (anulación).
// Every void requires the manager approval code and a reason; the reason drives
// what happened to stock (most reasons restore it, "merma" reclassifies the
// loss — see lib/consumos/removalReasons.ts). No FK to Event/Insumo on purpose:
// the audit must survive deletions. Surfaced in the event's consumos report.
model RemovedConsumo {
  id                String   @id @default(cuid())
  eventId           String // loose ref (no FK), for grouping
  eventName         String // snapshot
  insumoName        String // snapshot
  tableNumber       Int
  qty               Int
  unitPrice         Int // cents at capture time
  reason            String // RemovalReason key (arrepentimiento | error-carga | error-entrega | merma | otro)
  reasonText        String? // free text, required when reason = "otro"
  payerType         String   @default("CLIENTE") // snapshot of who owed the voided line
  payerLabel        String?
  originalCreatedAt DateTime // the removed line's createdAt
  removedAt         DateTime @default(now())

  @@index([eventId])
  @@index([reason])
}

// ─── Audit: removed event lines ───────────────────────────────────────────────
// Append-only snapshot taken when a provider/service/staff line is removed from
// an event. The live join row is deleted physically (financials/reports stay
// simple); this table keeps the history so the pago tables can show "Eliminado".
// No FK to Event — the snapshot must survive event deletion.
model RemovedEventLine {
  id                String    @id @default(cuid())
  kind              String    // "provider" | "service" | "staff"
  eventId           String    // loose ref (no FK), for grouping
  eventName         String    // snapshot
  entityName        String    // provider/staff/service name snapshot
  entityRole        String?   // provider/staff role snapshot
  amount            Int       // cents at removal time
  paid              Boolean   @default(false)
  paidAt            DateTime?
  originalCreatedAt DateTime  // the removed line's createdAt
  removedAt         DateTime  @default(now())

  @@index([kind])
  @@index([eventId])
}

// ─── Audit: reversed payments ─────────────────────────────────────────────────
// Append-only snapshot taken when a settled payment is reversed ("Anular pago").
// Every reversal requires the manager approval code and a reason. The reversal
// does NOT delete the original EGRESO: it posts a compensating INGRESO (kind
// "reversal") that nets the account back to zero, so the money trail survives.
// No FK to Event — the snapshot must outlive event/line deletion.
model ReversedPayment {
  id               String   @id @default(cuid())
  kind             String   // "provider" | "service" | "staff" | "compra"
  eventId          String?  // loose ref (no FK); null for compra (not event-bound)
  eventName        String?  // snapshot
  entityName       String   // provider/staff/prestador/proveedor name snapshot
  amount           Int      // cents reversed (the exact original EGRESO amount)
  reason           String   // ReversalReason key
  reasonText       String?  // free text, required when reason = "otro"
  originalMovementId String // the EGRESO that was reversed (snapshot, no FK)
  reversalMovementId String // the compensating INGRESO that was posted (snapshot)
  originalPaidAt   DateTime // when the line had been paid
  reversedAt       DateTime @default(now())

  @@index([kind])
  @@index([eventId])
  @@index([reason])
}
